# FreeGPT Telegram Bot — configuration
#
# Fill in TELEGRAM_BOT_TOKEN and at least one provider key.
# Any provider without a key is hidden from /model.
# LLM7.io works even without a key (limited).

TELEGRAM_BOT_TOKEN=

# --- Provider APIs --------------------------------------------------
# Cohere                    https://dashboard.cohere.com/api-keys
COHERE_API_KEY=
# Google Gemini             https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Mistral AI                https://console.mistral.ai/api-keys
MISTRAL_API_KEY=
# Z AI (Zhipu)              https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=

# --- Inference providers --------------------------------------------
# Cerebras                  https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# GitHub Models             https://github.com/settings/personal-access-tokens (any token works)
GITHUB_TOKEN=
# Groq (also used for voice https://console.groq.com/keys
#       transcription — Whisper)
GROQ_API_KEY=
# Hugging Face              https://huggingface.co/settings/tokens
HF_TOKEN=
# Kilo Code                 https://app.kilo.ai
KILO_API_KEY=
# LLM7.io                   https://token.llm7.io  (optional — works without)
LLM7_API_KEY=
# ModelScope                https://modelscope.cn/my/myaccesstoken
MODELSCOPE_API_KEY=
# NVIDIA NIM                https://build.nvidia.com
NVIDIA_API_KEY=
# OpenRouter                https://openrouter.ai/keys
OPENROUTER_API_KEY=
# SiliconFlow               https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=

# --- Optional tuning ------------------------------------------------
# Path to data.json (default: ../data.json relative to bot/)
# DATA_JSON_PATH=
# How many past messages to keep per user (default 20)
# HISTORY_LIMIT=20
# System prompt prepended to every conversation (optional)
# SYSTEM_PROMPT=
